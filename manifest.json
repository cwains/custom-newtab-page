{
  "manifest_version": 3,
  "name": "Better New Tab",
  "version": "1.0",
  "description": "Customizable new tab with widgets, GIFs, clock, and presets",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "permissions": [
    "storage"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}